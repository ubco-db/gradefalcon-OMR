{
  "name": "node-docker-good-defaults",
  "private": true,
  "version": "2.0.1",
  "description": "Node.js Hello world app using docker features for easy docker compose local dev and solid production defaults",
  "author": "Bret Fisher <bret@bretfisher.com>",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "start:ts": "ts-node src/index.ts",
    "dev": "nodemon --watch src --ignore src/assets --ignore /code/omr/inputs --ext ts,js --exec \"ts-node src/index.ts\" --inspect=0.0.0.0:9229",
    "dev-wait-debugger": "nodemon --watch src --ignore src/assets --ignore /code/omr/inputs --ext ts,js --exec \"ts-node src/index.ts\" --inspect-brk=0.0.0.0:9229",
    "start-watch": "nodemon --watch src --ignore src/assets --ignore /code/omr/inputs --ext ts,js --exec \"ts-node src/index.ts\" --inspect=0.0.0.0:9229",
    "start-wait-debuger": "nodemon --watch src --ignore src/assets --ignore /code/omr/inputs src/index.js --inspect-brk=0.0.0.0:9229",
    "test": "npx jest --config=jest.backend.config.js",
    "test-watch": "nodemon --watch src --ignore src/assets --ignore /code/omr/inputs --exec \"npm test\""
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.2.4",
    "@aws-sdk/client-s3": "^3.614.0",
    "auth0": "^4.7.0",
    "axios": "^1.7.3",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cassandra-driver": "^4.7.2",
    "connect-pg-simple": "^9.0.1",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-jwt": "^8.4.1",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "express-session": "^1.18.0",
    "form-data": "^4.0.2",
    "fs": "^0.0.1-security",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.10.0",
    "node-fetch": "^2.7.0",
    "path": "^0.12.7",
    "pdf-lib": "^1.17.1",
    "pg": "^8.12.0",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.2.0",
    "chai": "^4.3.7",
    "cross-env": "^7.0.2",
    "jest": "^27.5.1",
    "nodemon": "^2.0.4",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
