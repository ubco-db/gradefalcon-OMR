{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "checkJs": false,
    "noImplicitAny": false,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.js",
    "src/integrations/*.js"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "esm": false,
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true,
    "compilerOptions": {
      "allowJs": true,
      "checkJs": false,
      "noEmit": true,
      "skipLibCheck": true
    }
  }
}
